    COLA_GENERAL --> VALIDAR_DISPONIBILIDAD
    
    VALIDAR_DISPONIBILIDAD{"🕐 VALIDAR DISPONIBILIDAD<br/>¿Cliente registrado?<br/>¿Mascota válida?"}
    
