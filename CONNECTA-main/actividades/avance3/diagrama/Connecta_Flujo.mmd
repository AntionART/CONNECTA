    CONSULTA_REALIZADA -->|❌ NO| REGISTRAR_INCIDENCIA["⚠️ Registrar incidencia"]
    REGISTRAR_INCIDENCIA --> FIN8(["❌ FIN"])
    
    CONSULTA_REALIZADA -->|✅ SÍ| REQUIERE_SEGUIMIENTO{"🔄 ¿REQUIERE<br/>SEGUIMIENTO?"}
    
    REQUIERE_SEGUIMIENTO -->|✅ SÍ| CREAR_RECORDATORIO["🔔 Crear recordatorio<br/>según gravedad"]
    CREAR_RECORDATORIO --> MEDICAMENTOS{"💊 ¿MEDICAMENTOS<br/>PRESCRITOS?"}
    
    REQUIERE_SEGUIMIENTO -->|❌ NO| MEDICAMENTOS
    
    MEDICAMENTOS -->|✅ SÍ| GENERAR_RECOMENDACIONES["💡 Generar recomendaciones<br/>de cuidado"]
    GENERAR_RECOMENDACIONES --> FIN_FINAL(["✅ FIN EXITOSO"])
    
    MEDICAMENTOS -->|❌ NO| SOLO_MONITOREO["👀 Solo monitoreo"]
    SOLO_MONITOREO --> FIN_FINAL
    
